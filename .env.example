# ─── Base de Datos MySQL (origen, solo usada por sync_to_supabase.py) ──────
DB_HOST=TU_HOST_MYSQL
DB_PORT=3306
DB_DATABASE=bbdd_config
DB_USERNAME=TU_USUARIO
DB_PASSWORD=TU_PASSWORD

# ─── Supabase / Postgres (destino, usada por la app Flask) ─────────────────
SUPABASE_DB_HOST=db.xxxxxxxxxxxx.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=TU_PASSWORD_SUPABASE

# ─── Supabase REST API (solo usada por sync_to_supabase.py si el puerto ────
# Postgres directo está bloqueado por la red local; viaja por HTTPS 443) ────
SUPABASE_PROJECT_REF=TU_PROJECT_REF
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# ─── Aplicación Flask ───────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=5000
DEBUG=False
SECRET_KEY=cambia-este-valor-por-una-clave-aleatoria-segura
